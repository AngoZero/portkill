{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PortKill",
  "version": "0.3.0",
  "identifier": "com.angozero.portkill",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PortKill",
        "width": 480,
        "height": 640,
        "resizable": false,
        "visible": true,
        "decorations": true,
        "alwaysOnTop": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
